# CLI Task Manager — environment variables
# Copy this file to .env and modify as needed.
# Note: .env is in .gitignore for security.

# SQLite database location (absolute path).
# Default: ~/.task-manager/tasks.db
TASK_MANAGER_DB=~/.task-manager/tasks.db

# Logger verbosity: DEBUG / INFO / WARNING / ERROR
# Default: WARNING (logs stay out of the CLI's UX).
TASK_MANAGER_LOG_LEVEL=WARNING
