# CLI Task Manager Configuration Example
# Copy this file to .env and modify values as needed
# Note: .env is in .gitignore for security

# Database path (relative or absolute)
# Default: ~/.task-manager/tasks.db
TASK_DB_PATH=~/.task-manager/tasks.db

# Default project name for new tasks
DEFAULT_PROJECT=General

# Default priority for new tasks (high, medium, low)
DEFAULT_PRIORITY=medium

# Default status for new tasks (pending, in_progress, done)
DEFAULT_STATUS=pending

# Enable colored output (true/false)
ENABLE_COLORS=true

# Date format (python strftime format)
DATE_FORMAT=%Y-%m-%d

# Enable verbose logging
VERBOSE=false
